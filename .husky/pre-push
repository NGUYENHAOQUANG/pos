echo "🔍 Đang kiểm tra ESLint cho toàn bộ project..."

# Chạy ESLint với --max-warnings=0 để fail nếu có warnings
npx eslint . --max-warnings=0

# Kiểm tra exit code
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ ESLint phát hiện lỗi hoặc warnings!"
  echo "💡 Vui lòng sửa lỗi trước khi push."
  echo "💡 Chạy 'npm run lint:fix' để tự động fix một số lỗi."
  exit 1
fi

echo "✅ Tất cả file đã pass ESLint check!"

