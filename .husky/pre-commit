echo "🔍 Đang kiểm tra ESLint cho các file đã staged..."

npx lint-staged

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ ESLint phát hiện lỗi hoặc warnings!"
  echo "💡 Vui lòng sửa lỗi trước khi commit."
  echo "💡 Chạy 'npm run lint:fix' để tự động fix một số lỗi."
  exit 1
fi

echo "✅ Tất cả file đã pass ESLint check!"
